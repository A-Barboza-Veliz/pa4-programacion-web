# URL base de la API de cursos (si se consume desde un backend externo).
# Si se omite, las páginas leen /public/cursos.json como fuente estática para SSG.
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# URL del Portal del Estudiante (React) para el botón "Iniciar sesión"
NEXT_PUBLIC_PORTAL_ESTUDIANTE_URL=http://localhost:5173
